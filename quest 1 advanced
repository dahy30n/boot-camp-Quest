
#include <iostream>
#include <vector>
using namespace std;

vector<int> status(6);
bool check = false;

int addPotion(int potion) {
    potion += 1;
    return potion;
}

void setPotion(int count, int* p_HPPotion, int* p_MPPotion) {
    if (count == 1) {
        if (*p_HPPotion > 0) {
            status[0] += 20;
            (*p_HPPotion)--;
        }
        else {
            cout << "HP 포션이 없습니다.\n";
        }
    }
    else if (count == 2) {
        if (*p_MPPotion > 0) {
            status[1] += 20;
            (*p_MPPotion)--;
        }
        else {
            cout << "MP 포션이 없습니다.\n";
        }
    }
    else if (count == 3) {
        status[2] *= 2;
    }
    else if (count == 4) {
        status[3] *= 2;
    }
    else if (count == 5) {
        cout << "HP:" << status[0] << " MP:" << status[1]
             << " ATK:" << status[2] << " DEF:" << status[3]
             << " LV:" << status[4] << " ATTR:" << status[5]
             << " HP포션:" << *p_HPPotion
             << " MP포션:" << *p_MPPotion << '\n';
    }
    else if (count == 6) {
        *p_MPPotion = addPotion(*p_MPPotion);
        *p_HPPotion = addPotion(*p_HPPotion);
        status[4]++;
        status[5] += 20;
    }
    else if (count == 0) {
        check = true;
    }
    else {
        cout << "잘못된 입력입니다. 0~6 중에서 선택하세요.\n";
    }
}
int main() {
    
    for (int i = 0; i < 4; i++) {
        status[i] = 0;
    }
    status[4] = 0; //level 
    status[5] = 10; //Attractiveness
    
    while (cin >> status[0] >> status[1]) {
        if (status[0] <= 50 || status[1] <= 50) {
            cout << "다시 입력하세요.\n";
        }   
        else break;
    }
    while (cin >> status[2] >> status[3]) {
        if (status[2] <= 0 || status[3] <= 0) {
            cout << "다시 입력하세요.\n";
        }   
        else break;
    }
    
    int hp = 5, mp = 5, n = 0;
    while (true) {
        cout << "1.HP UP / 2.MP UP / 3.공격력 UP / 4.방어력 UP / 5.현재 능력치 / 6.Level Up / 0.나가기" << "\n";
        cin >> n; 
        setPotion(n, &hp, &mp);    
        if (check == true) break;
    }
    
}
