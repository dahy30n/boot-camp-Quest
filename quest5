
#include "MyMoverActor.h"
#include "Engine/Engine.h"

AMyMoverActor::AMyMoverActor()
{
	PrimaryActorTick.bCanEverTick = false;
}

void AMyMoverActor::BeginPlay()
{
    Super::BeginPlay();

    SetActorLocation(FVector(0.f, 50.f, 0.f));
    SetActorRotation(FRotator(0.f, 0.f, 0.f));
    printPosition();

    for (int32 i = 0; i < 10; i++)
    {
        float moveDist = FMath::RandRange(100.f, 300.f);
        float turnDeg = FMath::RandRange(-90.f, 90.f);

        moveActor(moveDist);
        turnActor(turnDeg);
        printPosition();
    }
}

void AMyMoverActor::moveActor(float distance)
{
    FVector newLocation = GetActorLocation() + GetActorForwardVector() * distance;
    SetActorLocation(newLocation);
}

void AMyMoverActor::turnActor(float yawDelta)
{
    FRotator newRot = GetActorRotation();
    newRot.Yaw += yawDelta;
    SetActorRotation(newRot);
}

void AMyMoverActor::printPosition()
{
    if (GEngine)
    {
        FVector p = GetActorLocation();
        FString msg = FString::Printf(TEXT("X=%.0f Y=%.0f Z=%.0f"), p.X, p.Y, p.Z);
        GEngine->AddOnScreenDebugMessage(-1, 3.f, FColor::Yellow, msg);
    }
}
